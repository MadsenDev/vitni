{
  "name": "vitni",
  "version": "0.1.3",
  "description": "Vitni - local-first investigation workspace",
  "main": "dist/main/app/main/main.js",
  "author": {
    "name": "Christoffer Madsen",
    "email": "chris@madsens.dev"
  },
  "license": "MIT",
  "scripts": {
    "postinstall": "npm run rebuild:native",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p app/main/tsconfig.json",
    "build:preload": "tsc -p app/preload/tsconfig.json",
    "build:renderer": "vite build --config app/renderer/vite.config.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "package": "npm run build && electron-builder --publish never",
    "package:linux": "npm run build && electron-builder --linux AppImage tar.gz --publish never",
    "package:win": "npm run build && electron-builder --win portable zip --publish never",
    "test:renderer": "vitest run --config app/renderer/vite.config.ts",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p app/main/tsconfig.json --watch",
    "dev:preload": "tsc -p app/preload/tsconfig.json --watch",
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "dev:electron": "wait-on dist/main/app/main/main.js dist/preload/app/preload/preload.js http://localhost:5173 && cross-env NODE_ENV=development PI_DB_KEY=dev-key-123 electron .",
    "lint": "eslint --ext .ts,.tsx app/main app/preload app/renderer/src shared",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "npm run build && cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "@types/papaparse": "^5.5.2",
    "better-sqlite3": "^12.4.1",
    "cytoscape": "3.27.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "electron-store": "8.1.0",
    "framer-motion": "12.23.24",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "18.2.0",
    "react-cytoscapejs": "2.0.0",
    "react-dom": "18.2.0",
    "react-icons": "^5.5.0",
    "zod": "3.23.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/forms": "0.5.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "20.10.5",
    "@types/react": "18.2.37",
    "@types/react-dom": "18.2.15",
    "@typescript-eslint/eslint-plugin": "6.14.0",
    "@typescript-eslint/parser": "6.14.0",
    "@vitejs/plugin-react": "4.2.1",
    "autoprefixer": "10.4.16",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "27.1.3",
    "electron-builder": "^25.1.8",
    "eslint": "8.55.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.33.2",
    "jsdom": "^26.1.0",
    "postcss": "8.4.32",
    "tailwindcss": "3.3.6",
    "typescript": "5.3.3",
    "vite": "5.0.5",
    "vitest": "^2.1.8",
    "wait-on": "7.1.0"
  }
}
