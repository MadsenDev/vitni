{
  "id": "whois.lookup",
  "name": "WHOIS Lookup",
  "description": "Look up domain registration and registrant details via RDAP.",
  "appliesTo": ["domain", "website"],
  "input": [{ "entityType": "domain" }, { "entityType": "website" }],
  "network": {
    "kind": "http",
    "host": "rdap.org",
    "path": "/domain/${domain}",
    "method": "GET",
    "sends": ["domain"],
    "receives": ["registrar", "contacts", "dates"]
  },
  "outputs": [
    { "type": "entity", "entityType": "org", "from": "registrar.name" },
    { "type": "edge", "edgeType": "registered_by", "from": "contacts.registrant" }
  ]
}
