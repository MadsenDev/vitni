{
  "id": "ip.lookup",
  "name": "IP Lookup",
  "description": "Look up provider, ASN, reverse DNS, and geolocation for an IP address.",
  "appliesTo": ["ip_address"],
  "input": [{ "entityType": "ip_address" }],
  "network": {
    "kind": "http",
    "host": "ipwhois.app",
    "path": "/json/${ipAddress}",
    "method": "GET",
    "sends": ["ipAddress"],
    "receives": ["asn", "provider", "reverseDns", "country", "city"]
  }
}
